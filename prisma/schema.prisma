generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  pending
  played
  walkover
}

enum UserRole {
  ADMIN
  PLAYER
}

enum SeasonStatus {
  active
  closed
}

enum CupRound {
  roundOf64
  roundOf32
  roundOf16
  quarterfinal
  semifinal
  final
}

model Season {
  id        Int          @id @default(autoincrement())
  name      String
  status    SeasonStatus @default(active)
  createdAt DateTime     @default(now())
  closedAt  DateTime?

  matches     Match[]
  cupMatches  CupMatch[]
  seasonTeams SeasonTeam[]
}

model SeasonTeam {
  id       Int @id @default(autoincrement())
  seasonId Int
  teamId   Int
  division Int

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId])
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  logoUrl     String?
  division    Int
  cupEnabled  Boolean  @default(true)
  createdAt   DateTime @default(now())

  homeMatches    Match[]    @relation("HomeTeam")
  awayMatches    Match[]    @relation("AwayTeam")
  homeCupMatches CupMatch[] @relation("HomeCupTeam")
  awayCupMatches CupMatch[] @relation("AwayCupTeam")
  seasonTeams    SeasonTeam[]
}

model Match {
  id         Int         @id @default(autoincrement())
  seasonId   Int
  division   Int
  homeTeamId Int
  awayTeamId Int
  homeSets   Int?
  awaySets   Int?
  setDetails String?
  matchday   Int?
  date       DateTime?
  status     MatchStatus @default(pending)
  createdAt  DateTime    @default(now())
  playedAt   DateTime?

  season   Season @relation(fields: [seasonId], references: [id])
  homeTeam Team   @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam Team   @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
}

model CupMatch {
  id          Int         @id @default(autoincrement())
  seasonId    Int
  round       CupRound
  order       Int         @default(0)
  homeTeamId  Int?
  awayTeamId  Int?
  homeSets    Int?
  awaySets    Int?
  setDetails  String?
  date        DateTime?
  status      MatchStatus @default(pending)
  createdAt   DateTime    @default(now())
  playedAt    DateTime?
  nextMatchId Int?
  nextSlot    String?

  season      Season     @relation(fields: [seasonId], references: [id])
  homeTeam    Team?      @relation("HomeCupTeam", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeam    Team?      @relation("AwayCupTeam", fields: [awayTeamId], references: [id], onDelete: SetNull)
  nextMatch   CupMatch?  @relation("CupAdvance", fields: [nextMatchId], references: [id], onDelete: SetNull)
  prevMatches CupMatch[] @relation("CupAdvance")
}

model AdminUser {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  passwordHash String
  name         String?
  role         UserRole       @default(ADMIN)
  createdAt    DateTime       @default(now())
  sessions     AdminSession[]
}

model AdminSession {
  id        String    @id
  userId    Int
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  summary   String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
}
